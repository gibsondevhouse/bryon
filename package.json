{
	"name": "bryon",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.25.0",
	"engines": {
		"node": "22.x",
		"pnpm": ">=10.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"gate": "pnpm lint && pnpm check && pnpm test && pnpm test:e2e && pnpm build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:reconcile-drift": "tsx scripts/reconcile-migration-drift.ts",
		"llm:verify": "tsx scripts/verify-ollama-stream.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "latest",
		"@sveltejs/kit": "latest",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.19",
		"@types/pdf-parse": "^1.1.5",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.22.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@tanstack/svelte-virtual": "^3.13.24",
		"better-sqlite3": "^12.10.0",
		"dompurify": "^3.4.4",
		"drizzle-orm": "^0.45.2",
		"exifr": "^7.1.3",
		"marked": "^18.0.3",
		"pdf-parse": "^2.4.5",
		"pino": "^10.3.1",
		"shiki": "^4.0.2",
		"smol-toml": "^1.6.1",
		"sqlite-vec": "^0.1.9",
		"zod": "^4.4.3"
	}
}
